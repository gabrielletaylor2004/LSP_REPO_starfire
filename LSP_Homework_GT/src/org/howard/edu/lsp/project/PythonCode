        )
        event2 = self.event_service.create_event(
            "Leadership Summit",
            datetime(2026, 4, 21, 14, 0),
            "Main Hall",
            50
        )

        self.registration_manager.register_user_for_event(user1.user_id, event1.event_id)
        self.registration_manager.register_user_for_event(user2.user_id, event2.event_id)

    def run(self) -> None:
        while True:
            print("\n===== EVENT MANAGEMENT SYSTEM =====")
            print("1. Create User")
            print("2. Create Event")
            print("3. Register User for Event")
            print("4. Show Users")
            print("5. Show Events")
            print("6. Show Tickets")
            print("7. Cancel Registration")
            print("8. Show Schedule")
            print("9. Show Analytics")
            print("10. Use Ticket")
            print("11. Exit")
