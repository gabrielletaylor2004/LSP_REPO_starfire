class EventManagementApp:
    def __init__(self) -> None:
        self.user_repository = UserRepository()
        self.event_repository = EventRepository()
        self.ticket_repository = TicketRepository()

        self.user_factory = UserFactory()
        self.event_factory = EventFactory()
        self.ticket_factory = TicketFactory()
        self.ticket_validator = TicketValidator()

        self.user_service = UserService(self.user_repository, self.user_factory)
        self.event_service = EventService(self.event_repository, self.event_factory)
        self.ticket_service = TicketService(
            self.ticket_repository,
            self.ticket_factory,
            self.ticket_validator
        )

        self.schedule_manager = ScheduleManager(self.event_service)
        self.registration_manager = RegistrationManager(
            self.user_service,
            self.event_service,
            self.ticket_service
        )
        self.analytics = Analytics(
            self.user_service,
            self.event_service,
            self.ticket_service
        )

