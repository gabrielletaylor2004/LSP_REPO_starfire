                location = input("Enter location: ").strip()
                capacity_str = input("Enter capacity: ").strip()

                try:
                    date_time = datetime.strptime(date_time_str, "%Y-%m-%d %H:%M")
                    capacity = int(capacity_str)

                    conflicts = self.schedule_manager.find_conflicts(date_time, location)
                    if conflicts:
                        print("Warning: schedule conflict detected:")
                        for conflict in conflicts:
                            print(conflict.display())
                    event = self.event_service.create_event(title, date_time, location, capacity)
                    print(event.display())
                except ValueError:
                    print("Invalid input.")

            elif choice == "3":
                user_id = input("Enter user ID: ").strip()
                event_id = input("Enter event ID: ").strip()
                try:
                    ticket = self.registration_manager.register_user_for_event(user_id, event_id)
                    print(ticket.display())
                except ValueError as error:
                    print(f"Error: {error}")

            elif choice == "4":
                for user in self.user_service.list_users():
                    print(user.display())

