from __future__ import annotations

from dataclasses import dataclass, field
from datetime import datetime
from typing import Dict, List, Optional
import uuid


# =========================================================
# ENTITIES
# =========================================================

@dataclass
class User:
    user_id: str
    name: str
    email: str

    def display(self) -> str:
        return f"{self.user_id} | {self.name} | {self.email}"


@dataclass
class Event:
    event_id: str
    title: str
    date_time: datetime
    location: str
    capacity: int
    registered_user_ids: List[str] = field(default_factory=list)

    def has_space(self) -> bool:
        return len(self.registered_user_ids) < self.capacity

    def add_user(self, user_id: str) -> bool:
        if user_id in self.registered_user_ids or not self.has_space():
            return False
        self.registered_user_ids.append(user_id)
        return True

    def remove_user(self, user_id: str) -> bool:
        if user_id not in self.registered_user_ids:
            return False
        self.registered_user_ids.remove(user_id)
        return True

    def update(
        self,
        title: Optional[str] = None,
        date_time: Optional[datetime] = None,
        location: Optional[str] = None,
        capacity: Optional[int] = None,
    ) -> bool:
        if capacity is not None and capacity < len(self.registered_user_ids):
            return False

        if title is not None:
            self.title = title
        if date_time is not None:
            self.date_time = date_time
        if location is not None:
            self.location = location
        if capacity is not None:
            self.capacity = capacity
        return True

    def seats_remaining(self) -> int:
        return self.capacity - len(self.registered_user_ids)

    def display(self) -> str:
        return (
            f"{self.event_id} | {self.title} | "
            f"{self.date_time.strftime('%Y-%m-%d %H:%M')} | {self.location} | "
            f"Capacity: {self.capacity} | Registered: {len(self.registered_user_ids)} | "
            f"Seats Left: {self.seats_remaining()}"
        )


@dataclass
class Ticket:
    ticket_id: str
    user_id: str
    event_id: str
    status: str = "active"

    def cancel(self) -> bool:
        if self.status != "active":
            return False
        self.status = "cancelled"
        return True

    def mark_used(self) -> bool:
        if self.status != "active":
            return False
        self.status = "used"
        return True

    def is_active(self) -> bool:
        return self.status == "active"

    def display(self) -> str:
        return f"{self.ticket_id} | User: {self.user_id} | Event: {self.event_id} | Status: {self.status}"


# =========================================================
# USER LAYER
# =========================================================

class UserRepository:
    def __init__(self) -> None:
        self._users: Dict[str, User] = {}

    def save(self, user: User) -> None:
        self._users[user.user_id] = user

    def get_by_id(self, user_id: str) -> Optional[User]:
        return self._users.get(user_id)

    def get_by_email(self, email: str) -> Optional[User]:
        for user in self._users.values():
            if user.email.lower() == email.lower():
                return user
        return None

    def list_all(self) -> List[User]:
        return list(self._users.values())


class UserFactory:
    @staticmethod
    def create(name: str, email: str) -> User:
        return User(
            user_id=f"USR-{str(uuid.uuid4())[:8]}",
            name=name,
            email=email
        )


class UserService:
    def __init__(self, user_repository: UserRepository, user_factory: UserFactory) -> None:
        self.user_repository = user_repository
        self.user_factory = user_factory

    def register_user(self, name: str, email: str) -> User:
        if self.user_repository.get_by_email(email) is not None:
            raise ValueError("A user with this email already exists.")

        user = self.user_factory.create(name, email)
        self.user_repository.save(user)
        return user

    def get_user(self, user_id: str) -> Optional[User]:
        return self.user_repository.get_by_id(user_id)

    def list_users(self) -> List[User]:
        return self.user_repository.list_all()


# =========================================================
# EVENT LAYER
# =========================================================

class EventRepository:
    def __init__(self) -> None:
        self._events: Dict[str, Event] = {}

    def save(self, event: Event) -> None:
        self._events[event.event_id] = event

    def get_by_id(self, event_id: str) -> Optional[Event]:
        return self._events.get(event_id)

    def delete(self, event_id: str) -> bool:
        if event_id not in self._events:
            return False
        del self._events[event_id]
        return True

    def list_all(self) -> List[Event]:
        return list(self._events.values())


class EventFactory:
    @staticmethod
    def create(title: str, date_time: datetime, location: str, capacity: int) -> Event:
        return Event(
            event_id=f"EVT-{str(uuid.uuid4())[:8]}",
            title=title,
            date_time=date_time,
            location=location,
            capacity=capacity
        )


class EventService:
    def __init__(self, event_repository: EventRepository, event_factory: EventFactory) -> None:
        self.event_repository = event_repository
        self.event_factory = event_factory

    def create_event(self, title: str, date_time: datetime, location: str, capacity: int) -> Event:
        event = self.event_factory.create(title, date_time, location, capacity)
        self.event_repository.save(event)
        return event

    def update_event(
        self,
        event_id: str,
        title: Optional[str] = None,
        date_time: Optional[datetime] = None,
        location: Optional[str] = None,
        capacity: Optional[int] = None,
    ) -> bool:
        event = self.event_repository.get_by_id(event_id)
        if event is None:
            return False
        return event.update(title, date_time, location, capacity)

    def delete_event(self, event_id: str) -> bool:
        return self.event_repository.delete(event_id)

    def get_event(self, event_id: str) -> Optional[Event]:
        return self.event_repository.get_by_id(event_id)

    def list_events(self) -> List[Event]:
        return self.event_repository.list_all()


# =========================================================
# TICKET LAYER
# =========================================================

class TicketRepository:
    def __init__(self) -> None:
        self._tickets: Dict[str, Ticket] = {}

    def save(self, ticket: Ticket) -> None:
        self._tickets[ticket.ticket_id] = ticket

    def get_by_id(self, ticket_id: str) -> Optional[Ticket]:
        return self._tickets.get(ticket_id)

    def list_all(self) -> List[Ticket]:
        return list(self._tickets.values())

    def list_by_user(self, user_id: str) -> List[Ticket]:
        return [ticket for ticket in self._tickets.values() if ticket.user_id == user_id]

    def list_by_event(self, event_id: str) -> List[Ticket]:
        return [ticket for ticket in self._tickets.values() if ticket.event_id == event_id]


class TicketFactory:
    @staticmethod
    def create(user_id: str, event_id: str) -> Ticket:
        return Ticket(
            ticket_id=f"TKT-{str(uuid.uuid4())[:8]}",
            user_id=user_id,
            event_id=event_id
        )


class TicketValidator:
    def is_valid(self, ticket: Optional[Ticket]) -> bool:
        return ticket is not None and ticket.is_active()

    def has_active_ticket_for_event(self, tickets: List[Ticket], user_id: str, event_id: str) -> bool:
        return any(
            ticket.user_id == user_id and
            ticket.event_id == event_id and
            ticket.status == "active"
            for ticket in tickets
        )


class TicketService:
    def __init__(
        self,
        ticket_repository: TicketRepository,
        ticket_factory: TicketFactory,
        ticket_validator: TicketValidator
    ) -> None:
        self.ticket_repository = ticket_repository
        self.ticket_factory = ticket_factory
        self.ticket_validator = ticket_validator

    def issue_ticket(self, user_id: str, event_id: str) -> Ticket:
        ticket = self.ticket_factory.create(user_id, event_id)
        self.ticket_repository.save(ticket)
        return ticket

    def validate_ticket(self, ticket_id: str) -> bool:
        ticket = self.ticket_repository.get_by_id(ticket_id)
        return self.ticket_validator.is_valid(ticket)

    def cancel_ticket(self, ticket_id: str) -> bool:
        ticket = self.ticket_repository.get_by_id(ticket_id)
        if ticket is None:
            return False
        return ticket.cancel()

    def use_ticket(self, ticket_id: str) -> bool:
        ticket = self.ticket_repository.get_by_id(ticket_id)
        if ticket is None:
            return False
        return ticket.mark_used()

    def get_ticket(self, ticket_id: str) -> Optional[Ticket]:
        return self.ticket_repository.get_by_id(ticket_id)

    def list_tickets(self) -> List[Ticket]:
        return self.ticket_repository.list_all()

    def list_tickets_for_user(self, user_id: str) -> List[Ticket]:
        return self.ticket_repository.list_by_user(user_id)

    def list_tickets_for_event(self, event_id: str) -> List[Ticket]:
        return self.ticket_repository.list_by_event(event_id)

    def user_already_registered(self, user_id: str, event_id: str) -> bool:
        tickets = self.ticket_repository.list_by_user(user_id)
        return self.ticket_validator.has_active_ticket_for_event(tickets, user_id, event_id)


# =========================================================
# SCHEDULE MANAGER
# =========================================================

class ScheduleManager:
    def __init__(self, event_service: EventService) -> None:
        self.event_service = event_service

    def get_schedule(self) -> List[Event]:
        return sorted(self.event_service.list_events(), key=lambda event: event.date_time)

    def find_conflicts(self, date_time: datetime, location: str) -> List[Event]:
        conflicts: List[Event] = []
        for event in self.event_service.list_events():
            if event.date_time == date_time and event.location.lower() == location.lower():
                conflicts.append(event)
        return conflicts

    def format_schedule(self) -> str:
        events = self.get_schedule()
        if not events:
            return "No events scheduled."

        lines = ["===== EVENT SCHEDULE ====="]
        for event in events:
            lines.append(f"{event.date_time.strftime('%b %d, %Y %I:%M %p')} - {event.title}")

        return "\n".join(lines)


# =========================================================
# REGISTRATION MANAGER
# =========================================================

class RegistrationManager:
    def __init__(
        self,
        user_service: UserService,
        event_service: EventService,
        ticket_service: TicketService
    ) -> None:
        self.user_service = user_service
        self.event_service = event_service
        self.ticket_service = ticket_service

    def register_user_for_event(self, user_id: str, event_id: str) -> Ticket:
        user = self.user_service.get_user(user_id)
        if user is None:
            raise ValueError("User not found.")

        event = self.event_service.get_event(event_id)
        if event is None:
            raise ValueError("Event not found.")

        if self.ticket_service.user_already_registered(user_id, event_id):
            raise ValueError("User is already registered for this event.")

        if not event.has_space():
            raise ValueError("Event is full.")

        if not event.add_user(user_id):
            raise ValueError("Registration failed.")

        return self.ticket_service.issue_ticket(user_id, event_id)

    def cancel_registration(self, ticket_id: str) -> bool:
        ticket = self.ticket_service.get_ticket(ticket_id)
        if ticket is None or ticket.status != "active":
            return False

        event = self.event_service.get_event(ticket.event_id)
        if event is None:
            return False

        if not self.ticket_service.cancel_ticket(ticket_id):
            return False

        event.remove_user(ticket.user_id)
        return True


# =========================================================
# ANALYTICS
# =========================================================

class Analytics:
    def __init__(
        self,
        user_service: UserService,
        event_service: EventService,
        ticket_service: TicketService
    ) -> None:
        self.user_service = user_service
        self.event_service = event_service
        self.ticket_service = ticket_service

    def total_users(self) -> int:
        return len(self.user_service.list_users())

    def total_events(self) -> int:
        return len(self.event_service.list_events())

    def total_tickets(self) -> int:
        return len(self.ticket_service.list_tickets())

    def active_tickets(self) -> int:
        return sum(1 for ticket in self.ticket_service.list_tickets() if ticket.status == "active")

    def cancelled_tickets(self) -> int:
        return sum(1 for ticket in self.ticket_service.list_tickets() if ticket.status == "cancelled")

    def used_tickets(self) -> int:
        return sum(1 for ticket in self.ticket_service.list_tickets() if ticket.status == "used")

    def most_popular_events(self) -> List[Event]:
        events = self.event_service.list_events()
        if not events:
            return []

        max_registrations = max(len(event.registered_user_ids) for event in events)
        return [
            event for event in events
            if len(event.registered_user_ids) == max_registrations
        ]

    def generate_report(self) -> str:
        popular_events = self.most_popular_events()

        lines = [
            "===== ANALYTICS REPORT =====",
            f"Total Users: {self.total_users()}",
            f"Total Events: {self.total_events()}",
            f"Total Tickets: {self.total_tickets()}",
            f"Active Tickets: {self.active_tickets()}",
            f"Cancelled Tickets: {self.cancelled_tickets()}",
            f"Used Tickets: {self.used_tickets()}",
        ]

        if not popular_events:
            lines.append("Most Popular Event: None")
        elif len(popular_events) == 1:
            event = popular_events[0]
            lines.append(
                f"Most Popular Event: {event.title} "
                f"({len(event.registered_user_ids)} registration/s)"
            )
        else:
            tied_titles = ", ".join(
                f"{event.title} ({len(event.registered_user_ids)} registration/s)"
                for event in popular_events
            )
            lines.append(f"Most Popular Events (tie): {tied_titles}")

        lines.append("============================")
        return "\n".join(lines)

